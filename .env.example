# ─── SERVER-SIDE ONLY (no VITE_/NEXT_PUBLIC_ prefix — never exposed) ───
# These live only in serverless functions under pages/api/ and the same-origin
# auth handler. NEVER prefix a secret with a public prefix.

# Anthropic key — claude-haiku-4-5 tagging. Server only.
ANTHROPIC_API_KEY=

# Neon connection string — full DB write access. Server only.
NEON_DATABASE_URL=

# Neon service-role connection for admin cross-scholar reads. Server only.
NEON_DATABASE_URL_ADMIN=

# YouTube Data API v3 key — quota abuse risk. Server only.
YOUTUBE_API_KEY=

# Neon Auth server URL — used by the same-origin auth handler
# (lib/auth/server.js) and by JWT/JWKS verification (pages/api/_auth.js).
NEON_AUTH_BASE_URL=

# Secret for signing the FIRST-PARTY session cookie issued by the same-origin
# Neon Auth handler. MUST be 32+ characters. Generate: openssl rand -base64 32
# Server only. The app uses a placeholder at build time only; the REAL value
# MUST be set in Vercel for sessions to work.
NEON_AUTH_COOKIE_SECRET=

# ─── NOTES ───
# The browser no longer talks to Neon Auth directly: the client (src/lib/auth.js)
# calls the app's own same-origin /api/auth/* proxy, so the old client-side
# VITE_NEON_AUTH_URL / VITE_NEON_AUTH_PUBLISHABLE_KEY are no longer required.
