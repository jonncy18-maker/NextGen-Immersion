# ─── SERVER-SIDE ONLY (no VITE_ prefix — never exposed to the browser) ───
# These live only in Vercel serverless functions under api/. NEVER prefix a
# secret with VITE_ — Vite inlines any VITE_ var into the browser bundle.

# Anthropic key — claude-haiku-4-5 tagging. Server only.
ANTHROPIC_API_KEY=

# Neon connection string — full DB write access. Server only.
NEON_DATABASE_URL=

# Neon service-role connection for admin cross-scholar reads. Server only.
NEON_DATABASE_URL_ADMIN=

# YouTube Data API v3 key — quota abuse risk. Server only.
YOUTUBE_API_KEY=

# Better Auth base URL — server-side (same value as VITE_NEON_AUTH_URL). Server only.
NEON_AUTH_BASE_URL=

# ─── CLIENT-SIDE (VITE_ prefix — safe to expose in the browser) ───

# Neon Auth publishable key — designed to be public.
VITE_NEON_AUTH_PUBLISHABLE_KEY=

# Better Auth base URL — client-safe (same value as NEON_AUTH_BASE_URL).
VITE_NEON_AUTH_URL=

# Build/runtime environment flag: development | production
VITE_APP_ENV=development
