{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/neon-auth/:path*",
      "destination": "https://ep-wandering-math-aj1k636g.neonauth.c-3.us-east-2.aws.neon.tech/neondb/auth/:path*"
    },
    {
      "source": "/((?!api/|neon-auth/).*)",
      "destination": "/index.html"
    }
  ]
}
